<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>The Digital Gold Rush — Preview</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,600&family=Space+Mono:ital,wght@0,400;0,700;1,400&family=Outfit:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #0b0a07;
    --surface: #141310;
    --surface2: #1c1a16;
    --gold: #c9922a;
    --gold-light: #e8b84b;
    --gold-dim: rgba(201,146,42,0.15);
    --text: #ede6d8;
    --muted: #8a8070;
    --rule: rgba(237,230,216,0.08);
    --accent-green: #3d6b4f;
    --accent-red: #8b3a2a;
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Outfit', sans-serif;
    font-weight: 300;
    line-height: 1.7;
    overflow-x: hidden;
  }

  /* ─── HERO ─── */
  .hero {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--rule);
  }

  .hero-bg-pattern {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle at 70% 50%, rgba(201,146,42,0.07) 0%, transparent 60%),
      repeating-linear-gradient(90deg, transparent, transparent 119px, var(--rule) 119px, var(--rule) 120px);
    pointer-events: none;
  }

  .hero-left {
    padding: 100px 70px 80px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    z-index: 1;
    border-right: 1px solid var(--rule);
  }

  .edition-tag {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 40px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .edition-tag::before {
    content: '';
    width: 24px;
    height: 1px;
    background: var(--gold);
  }

  .hero-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(54px, 6.5vw, 92px);
    font-weight: 700;
    line-height: 0.95;
    letter-spacing: -0.02em;
    margin-bottom: 10px;
  }

  .hero-title .the {
    font-weight: 400;
    font-style: italic;
    color: var(--muted);
    font-size: 0.55em;
    display: block;
  }

  .hero-title .gold { color: var(--gold-light); }

  .hero-subtitle {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(14px, 1.4vw, 17px);
    font-style: italic;
    color: var(--muted);
    margin: 28px 0 52px;
    max-width: 420px;
    line-height: 1.6;
  }

  .hero-promise {
    background: var(--gold-dim);
    border-left: 2px solid var(--gold);
    padding: 20px 24px;
    max-width: 420px;
    margin-bottom: 48px;
  }

  .hp-label {
    font-family: 'Space Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.25em;
    color: var(--gold);
    text-transform: uppercase;
    margin-bottom: 8px;
  }

  .hp-text {
    font-size: 14px;
    color: var(--text);
    line-height: 1.6;
  }

  .hero-nums {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    border-top: 1px solid var(--rule);
    padding-top: 32px;
    max-width: 480px;
  }

  .hnum {
    padding-right: 20px;
    border-right: 1px solid var(--rule);
    margin-right: 20px;
  }
  .hnum:last-child { border-right: none; margin-right: 0; padding-right: 0; }

  .hnum-val {
    font-family: 'Cormorant Garamond', serif;
    font-size: 34px;
    font-weight: 700;
    color: var(--gold-light);
    line-height: 1;
  }

  .hnum-lbl {
    font-family: 'Space Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.1em;
    color: var(--muted);
    margin-top: 4px;
  }

  .hero-right {
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 1;
    padding: 60px;
  }

  .book-wrap {
    perspective: 1000px;
  }

  .book-3d {
    width: 240px;
    height: 320px;
    position: relative;
    transform: rotateY(-12deg) rotateX(3deg);
    transform-style: preserve-3d;
    animation: bookFloat 5s ease-in-out infinite;
  }

  @keyframes bookFloat {
    0%, 100% { transform: rotateY(-12deg) rotateX(3deg) translateY(0); }
    50% { transform: rotateY(-12deg) rotateX(3deg) translateY(-14px); }
  }

  .book-face {
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, #1a1505 0%, #0d0b04 60%, #1a1505 100%);
    border: 1px solid rgba(201,146,42,0.3);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 32px 28px;
    box-shadow:
      4px 0 0 #050401,
      8px 0 0 #0a0901,
      12px 4px 30px rgba(0,0,0,0.8);
  }

  .book-ornament {
    width: 48px;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
    margin-bottom: 20px;
  }

  .book-title-text {
    font-family: 'Cormorant Garamond', serif;
    font-size: 26px;
    font-weight: 700;
    color: var(--text);
    text-align: center;
    line-height: 1.1;
    margin-bottom: 8px;
  }

  .book-the {
    font-family: 'Cormorant Garamond', serif;
    font-size: 13px;
    font-weight: 400;
    font-style: italic;
    color: var(--gold);
    text-align: center;
    margin-bottom: 4px;
  }

  .book-gold-text {
    font-family: 'Cormorant Garamond', serif;
    font-size: 28px;
    font-weight: 700;
    color: var(--gold-light);
    text-align: center;
    line-height: 1.0;
  }

  .book-divider {
    width: 60px;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
    margin: 16px auto;
  }

  .book-sub-text {
    font-family: 'Cormorant Garamond', serif;
    font-size: 9px;
    font-style: italic;
    color: rgba(237,230,216,0.4);
    text-align: center;
    line-height: 1.6;
    letter-spacing: 0.03em;
  }

  .book-year {
    font-family: 'Space Mono', monospace;
    font-size: 9px;
    color: var(--gold);
    letter-spacing: 0.2em;
    margin-top: 20px;
  }

  /* ─── SHARED SECTION STYLES ─── */
  .section-label {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .section-label::after {
    content: '';
    width: 40px;
    height: 1px;
    background: var(--gold);
    opacity: 0.5;
  }

  .section-h {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(32px, 4vw, 52px);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin-bottom: 16px;
  }

  .section-h em {
    font-style: italic;
    color: var(--gold-light);
  }

  .section-body {
    font-size: 15px;
    color: var(--muted);
    max-width: 580px;
    line-height: 1.75;
  }

  /* ─── WHY SECTION ─── */
  .why-section {
    padding: 110px 70px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    max-width: 1300px;
    margin: 0 auto;
    align-items: start;
  }

  .core-framework {
    background: var(--surface);
    border: 1px solid var(--rule);
    padding: 48px;
    position: relative;
  }

  .cf-title {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 32px;
    text-align: center;
  }

  .cf-items {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .cf-item {
    padding: 24px 0;
    border-bottom: 1px solid var(--rule);
    display: grid;
    grid-template-columns: 36px 1fr;
    gap: 20px;
    align-items: start;
  }

  .cf-item:last-child { border-bottom: none; }

  .cf-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 28px;
    font-weight: 700;
    color: var(--gold);
    line-height: 1;
  }

  .cf-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 20px;
    font-weight: 600;
    margin-bottom: 6px;
  }

  .cf-desc {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.6;
  }

  .cf-center-label {
    text-align: center;
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    color: var(--muted);
    font-size: 13px;
    padding: 20px 0;
    border-top: 1px solid var(--rule);
    margin-top: 8px;
  }

  .pipeline-table {
    margin-top: 40px;
  }

  .pt-row {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 12px;
    align-items: center;
    padding: 14px 0;
    border-bottom: 1px solid var(--rule);
    font-size: 13px;
  }

  .pt-row:first-child {
    font-family: 'Space Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.15em;
    color: var(--muted);
    text-transform: uppercase;
    padding-bottom: 12px;
  }

  .pt-pain { color: var(--text); }
  .pt-arrow { color: var(--gold); font-size: 16px; }
  .pt-product { color: var(--gold-light); font-style: italic; font-family: 'Cormorant Garamond', serif; font-size: 15px; }

  /* ─── COMPARISON TABLE ─── */
  .comparison-section {
    background: var(--surface);
    padding: 100px 70px;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }

  .comparison-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .comp-table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 50px;
    font-size: 14px;
  }

  .comp-table th {
    font-family: 'Space Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
    padding: 16px 24px;
    text-align: left;
    border-bottom: 1px solid rgba(201,146,42,0.4);
  }

  .comp-table th:last-child {
    color: var(--gold);
  }

  .comp-table td {
    padding: 18px 24px;
    border-bottom: 1px solid var(--rule);
    vertical-align: top;
  }

  .comp-table tr:hover td { background: rgba(255,255,255,0.02); }

  .comp-table td:first-child {
    color: var(--muted);
    font-size: 13px;
  }

  .comp-bad { color: #8b5a4a; }
  .comp-good { color: #5a9970; }

  /* ─── 5 TRIGGERS ─── */
  .triggers-section {
    padding: 110px 70px;
    max-width: 1300px;
    margin: 0 auto;
  }

  .triggers-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 2px;
    background: var(--rule);
    margin-top: 56px;
  }

  .trigger-card {
    background: var(--bg);
    padding: 36px 28px;
    position: relative;
    overflow: hidden;
    transition: background 0.25s;
  }

  .trigger-card:hover { background: var(--surface); }

  .trigger-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--gold);
    transform: scaleX(0);
    transition: transform 0.3s;
    transform-origin: left;
  }

  .trigger-card:hover::before { transform: scaleX(1); }

  .trig-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 52px;
    font-weight: 700;
    color: rgba(201,146,42,0.1);
    line-height: 1;
    margin-bottom: 12px;
  }

  .trig-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 18px;
    font-weight: 600;
    margin-bottom: 12px;
    color: var(--text);
    line-height: 1.2;
  }

  .trig-desc {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.6;
  }

  .trig-science {
    font-family: 'Space Mono', monospace;
    font-size: 9px;
    color: var(--gold);
    letter-spacing: 0.1em;
    margin-top: 14px;
  }

  /* ─── VALUE FORMULA ─── */
  .formula-section {
    background: var(--surface);
    padding: 80px 70px;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    text-align: center;
  }

  .formula-inner { max-width: 900px; margin: 0 auto; }

  .formula-label {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.25em;
    color: var(--gold);
    text-transform: uppercase;
    margin-bottom: 32px;
  }

  .formula-display {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(18px, 2.5vw, 28px);
    font-weight: 600;
    line-height: 1.3;
    color: var(--text);
    margin-bottom: 36px;
  }

  .formula-display .frac {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    vertical-align: middle;
    margin: 0 8px;
  }

  .formula-display .frac-top { border-bottom: 2px solid var(--gold); padding-bottom: 4px; }
  .formula-display .frac-bot { padding-top: 4px; }

  .formula-display .gold-term { color: var(--gold-light); }
  .formula-display .div-sign { color: var(--gold); font-size: 1.4em; vertical-align: middle; margin: 0 6px; }
  .formula-display .mult-sign { color: var(--muted); margin: 0 4px; }

  .formula-levers {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    margin-top: 12px;
    text-align: left;
  }

  .fl-item {
    background: var(--bg);
    padding: 20px;
    border: 1px solid var(--rule);
  }

  .fl-action {
    font-family: 'Space Mono', monospace;
    font-size: 9px;
    color: var(--gold);
    letter-spacing: 0.1em;
    margin-bottom: 8px;
  }

  .fl-text {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.5;
  }

  /* ─── PRICING SCIENCE ─── */
  .pricing-section {
    padding: 110px 70px;
    max-width: 1300px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 80px;
    align-items: start;
  }

  .pricing-principles {
    display: flex;
    flex-direction: column;
    gap: 2px;
    margin-top: 40px;
  }

  .pp-item {
    background: var(--surface);
    padding: 24px 28px;
    border-left: 2px solid transparent;
    transition: border-color 0.25s;
    cursor: default;
  }

  .pp-item:hover { border-left-color: var(--gold); }

  .pp-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 18px;
    font-weight: 600;
    margin-bottom: 6px;
  }

  .pp-desc {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.6;
  }

  .pricing-tiers {
    margin-top: 40px;
  }

  .tier-label {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.2em;
    color: var(--muted);
    text-transform: uppercase;
    margin-bottom: 20px;
  }

  .tier-card {
    background: var(--surface);
    border: 1px solid var(--rule);
    padding: 32px 36px;
    margin-bottom: 3px;
    position: relative;
    transition: border-color 0.25s;
  }

  .tier-card.featured {
    border-color: rgba(201,146,42,0.4);
    background: var(--surface2);
  }

  .tier-badge {
    font-family: 'Space Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.2em;
    padding: 4px 10px;
    margin-bottom: 12px;
    display: inline-block;
  }

  .tier-card:nth-child(1) .tier-badge { background: var(--surface2); color: var(--muted); border: 1px solid var(--rule); }
  .tier-card.featured .tier-badge { background: var(--gold-dim); color: var(--gold); border: 1px solid rgba(201,146,42,0.3); }
  .tier-card:nth-child(3) .tier-badge { background: var(--surface2); color: var(--muted); border: 1px solid var(--rule); }

  .tier-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 22px;
    font-weight: 600;
    margin-bottom: 8px;
  }

  .tier-desc {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.6;
  }

  /* ─── FUNNEL ARCH ─── */
  .funnel-section {
    background: var(--surface);
    padding: 110px 70px;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }

  .funnel-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .funnel-stages {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 0;
    margin-top: 60px;
    position: relative;
  }

  .funnel-stages::before {
    content: '';
    position: absolute;
    top: 32px;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
  }

  .fs-stage {
    padding: 0 16px;
    padding-top: 64px;
    text-align: center;
    position: relative;
  }

  .fs-dot {
    position: absolute;
    top: 24px;
    left: 50%;
    transform: translateX(-50%);
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--bg);
    border: 2px solid var(--gold);
    z-index: 1;
  }

  .fs-stage:nth-child(3) .fs-dot,
  .fs-stage:nth-child(4) .fs-dot { background: var(--gold); }

  .fs-num {
    font-family: 'Space Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.15em;
    color: var(--gold);
    margin-bottom: 10px;
  }

  .fs-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 16px;
    font-weight: 600;
    margin-bottom: 10px;
    line-height: 1.2;
  }

  .fs-desc {
    font-size: 12px;
    color: var(--muted);
    line-height: 1.6;
  }

  .funnel-metrics {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 2px;
    background: var(--rule);
    margin-top: 50px;
  }

  .fm-item {
    background: var(--bg);
    padding: 20px 16px;
    text-align: center;
  }

  .fm-metric {
    font-family: 'Cormorant Garamond', serif;
    font-size: 22px;
    font-weight: 700;
    color: var(--gold-light);
    line-height: 1;
    margin-bottom: 6px;
  }

  .fm-label {
    font-family: 'Space Mono', monospace;
    font-size: 8px;
    color: var(--muted);
    letter-spacing: 0.1em;
    margin-bottom: 4px;
  }

  .fm-name {
    font-size: 11px;
    color: var(--text);
    line-height: 1.4;
  }

  /* ─── VALUE LADDER ─── */
  .ladder-section {
    padding: 110px 70px;
    max-width: 1300px;
    margin: 0 auto;
  }

  .ladder-viz {
    margin-top: 60px;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .ladder-rung {
    display: grid;
    grid-template-columns: 100px 1fr auto;
    gap: 0;
    align-items: stretch;
    position: relative;
  }

  .lr-label {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding-right: 20px;
    font-family: 'Space Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.15em;
    color: var(--muted);
    text-transform: uppercase;
  }

  .lr-bar {
    display: flex;
    align-items: center;
    padding: 20px 28px;
    position: relative;
  }

  .ladder-rung:nth-child(1) .lr-bar { background: rgba(201,146,42,0.06); }
  .ladder-rung:nth-child(2) .lr-bar { background: rgba(201,146,42,0.10); }
  .ladder-rung:nth-child(3) .lr-bar { background: rgba(201,146,42,0.15); }
  .ladder-rung:nth-child(4) .lr-bar { background: rgba(201,146,42,0.21); }
  .ladder-rung:nth-child(5) .lr-bar { background: rgba(201,146,42,0.28); }

  .lr-type {
    font-family: 'Cormorant Garamond', serif;
    font-size: 18px;
    font-weight: 600;
    margin-right: 16px;
    color: var(--text);
  }

  .lr-example {
    font-size: 13px;
    color: var(--muted);
    font-style: italic;
  }

  .lr-price {
    display: flex;
    align-items: center;
    padding: 20px 28px;
    font-family: 'Cormorant Garamond', serif;
    font-size: 18px;
    font-weight: 600;
    color: var(--gold-light);
    background: var(--surface);
    white-space: nowrap;
    border-left: 1px solid var(--rule);
    min-width: 140px;
    justify-content: flex-end;
  }

  .ladder-math {
